! Low-settings Si SCF for elastic constant test (8-atom conventional cubic cell)
&CONTROL
  calculation = 'scf',
  prefix = 'si',
  outdir = './tmp',
  pseudo_dir = '/home/albert/Softwares/qe_p/tests/band_kpath/pseudo'
/

&SYSTEM
  ibrav = 0,
  nat = 8,
  ntyp = 1,
  ecutwfc = 30,
  ecutrho = 120
/

&ELECTRONS
  conv_thr = 1.0d-8
/

ATOMIC_SPECIES
  Si 28.0850 Si.pbe-nl-rrkjus_psl.1.0.0.UPF

CELL_PARAMETERS angstrom
    5.4310000000    0.0000000000    0.0000000000
    0.0000000000    5.4310000000    0.0000000000
    0.0000000000    0.0000000000    5.4310000000

ATOMIC_POSITIONS crystal
  Si    0.0000000000    0.0000000000    0.0000000000
  Si    0.5000000000    0.5000000000    0.0000000000
  Si    0.5000000000    0.0000000000    0.5000000000
  Si    0.0000000000    0.5000000000    0.5000000000
  Si    0.2500000000    0.2500000000    0.2500000000
  Si    0.7500000000    0.7500000000    0.2500000000
  Si    0.7500000000    0.2500000000    0.7500000000
  Si    0.2500000000    0.7500000000    0.7500000000

K_POINTS automatic
  4 4 4 0 0 0
