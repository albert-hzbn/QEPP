&CONTROL
  calculation = 'scf',
  prefix = 'si',
  outdir = './tmp',
  pseudo_dir = './pseudo',
  verbosity = 'low'
/
&SYSTEM
  ibrav = 2,
  celldm(1) = 10.262,
  nat = 2,
  ntyp = 1,
  ecutwfc = 40,
  ecutrho = 320,
  occupations = 'tetrahedra'
/
&ELECTRONS
  conv_thr = 1.0d-10
/
ATOMIC_SPECIES
  Si 28.0855 Si.pbe-nl-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Si 0.00 0.00 0.00
  Si 0.25 0.25 0.25
K_POINTS automatic
  16 16 16 0 0 0
