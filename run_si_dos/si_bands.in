! Generated bands input from SCF template + symmetry k-path
! K-path family: cF
! Path: L- G- X- W- K- G

&CONTROL
  calculation = 'bands',
  prefix = 'si',
  outdir = './tmp',
  pseudo_dir = './pseudo',
  verbosity = 'low'
/
&SYSTEM
  ibrav = 2,
  celldm(1) = 10.262,
  nat = 2,
  ntyp = 1,
  ecutwfc = 40,
  ecutrho = 320,
  occupations = 'fixed'
/
&ELECTRONS
  conv_thr = 1.0d-8
/
ATOMIC_SPECIES
  Si 28.0855 Si.pbe-nl-rrkjus_psl.1.0.0.UPF
ATOMIC_POSITIONS crystal
  Si 0.00 0.00 0.00
  Si 0.25 0.25 0.25

K_POINTS crystal_b
  6
   0.50000000  0.50000000  0.50000000 24 ! L
   0.00000000  0.00000000  0.00000000 24 ! G
   0.00000000  0.50000000  0.50000000 24 ! X
   0.25000000  0.75000000  0.50000000 24 ! W
   0.37500000  0.75000000  0.37500000 24 ! K
   0.00000000  0.00000000  0.00000000 1 ! G
